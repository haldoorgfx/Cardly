# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — subscription billing (existing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — event ticket payments (Phase 1)
STRIPE_TICKET_WEBHOOK_SECRET=

# Flutterwave — African payments (Phase 1)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# WaafiPay — Somalia & Djibouti mobile money (Phase 1.7)
WAAFIPAY_MERCHANT_UID=
WAAFIPAY_API_USER_ID=
WAAFIPAY_API_KEY=
WAAFIPAY_WEBHOOK_SECRET=

# Resend — email
# ⚠ Notification emails (registration, reminders, etc.) only send when this is set.
RESEND_API_KEY=
# Must be a BARE address (no display name, no angle brackets). The display name
# is set separately via RESEND_FROM_NAME — the app builds "Name <email>" for you.
RESEND_FROM_EMAIL=noreply@eventera.so
RESEND_FROM_NAME=Eventera

# Push notifications — Firebase Cloud Messaging (transport only; data stays in
# Supabase). Push stays a safe no-op until BOTH are set AND the mobile app ships
# with google-services.json / an APNs key so devices can register tokens.
# Create a Firebase project → Project settings → Service accounts → generate key.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT=   # the service-account JSON, single-line

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ERA — Eventera AI assistant (Google Gemini)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_KEY=

# AI Copilot (Claude / Anthropic)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Upstash Redis — rate limiting (optional; app works without it, all requests pass through)
# Create a Redis database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (optional) — DSNs for runtime error reporting; the AUTH_TOKEN/ORG/PROJECT
# trio is build-time only (source-map upload in next.config.mjs) and can be omitted.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Stripe — subscription price IDs (required for /pricing checkout)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=

# Resend — audience/list ID for newsletter signups (optional)
RESEND_AUDIENCE_ID=

# WaafiPay — set to "true" to use the sandbox environment
WAAFIPAY_SANDBOX=

# PostHog — product analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Google Maps — venue geocoding on event pages (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Crisp — live chat widget (optional)
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Mobile app store links (optional) — when set, the "Get the app" badges link to
# the real stores; unset = badges say "Coming soon" and point at /app.
NEXT_PUBLIC_IOS_APP_URL=
NEXT_PUBLIC_ANDROID_APP_URL=

# Cron — optional bearer secret for /api/cron/reminders (set it in Vercel and
# Vercel Cron sends it automatically; unset = endpoint is open but idempotent)
CRON_SECRET=

# Internal render secret — lets the authenticated public API (/api/v1/render)
# skip the attendee-registration gate on /api/render. Set to a strong random
# value in prod. If UNSET the bypass is disabled (fail-closed) and /api/v1/render
# will 403 — so this is REQUIRED for the Studio "render via API" feature to work.
INTERNAL_RENDER_SECRET=
