# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=https://karta.cre8so.com
NEXT_PUBLIC_SITE_URL=https://karta.cre8so.com

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_TICKET_WEBHOOK_SECRET=whsec_...   # Webhook for ticket payments (Developers > Webhooks)

# Stripe Price IDs — create products in Stripe dashboard, paste price IDs here
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_ANNUAL=price_...

# Flutterwave — get from dashboard.flutterwave.com (Settings > API Keys)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-hash   # Set in Flutterwave dashboard > Settings > Webhooks

# WaafiPay — get from WaafiPay merchant portal
WAAFIPAY_MERCHANT_UID=M0910291
WAAFIPAY_API_USER_ID=1000416
WAAFIPAY_API_KEY=API-123456789XXXXXXXXXX
WAAFIPAY_WEBHOOK_SECRET=your-webhook-secret
# WAAFIPAY_SANDBOX=true   # Uncomment to use sandbox endpoint

# Resend — transactional email (get from resend.com)
RESEND_API_KEY=re_...

# Google Maps — enable Maps JavaScript API at console.cloud.google.com
# Required for the event search map view (/events/search)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
